FuchsiaCity_House2_MapScripts::
	.byte 0

FuchsiaCity_House2_EventScript_FishingGurusBrother::
	lock
	faceplayer
	goto_if_set FLAG_GOT_HM07, FuchsiaCity_House2_EventScript_AlreadyHM07
	msgbox FuchsiaCity_House2_Text_DoYouLikeToFish, MSGBOX_YESNO
	goto_if_eq VAR_RESULT, YES, FuchsiaCity_House2_EventScript_GiveHM07
	msgbox FuchsiaCity_House2_Text_OhThatsDisappointing
	release
	end

FuchsiaCity_House2_EventScript_AlreadyHM07::
	msgbox FuchsiaCity_House2_Text_HowAreTheFishBiting
	release
	end

FuchsiaCity_House2_EventScript_GiveHM07::
	msgbox FuchsiaCity_House2_Text_LikeYourStyleTakeThis
	checkitemspace ITEM_HM07
	goto_if_eq VAR_RESULT, FALSE, FuchsiaCity_House2_EventScript_NoRoomForHM07
	giveitem_msg FuchsiaCity_House2_Text_ReceivedHM07, ITEM_HM07
	msgbox FuchsiaCity_House2_Text_CanCatchBetterMons
	setflag FLAG_GOT_HM07
	release
	end

FuchsiaCity_House2_EventScript_NoRoomForHM07::
	msgbox FuchsiaCity_House2_Text_YouHaveNoRoomForGift
	release
	end
